{
  "name": "@ohino/ui-components",
  "version": "1.0.0",
  "description": "Reusable UI component library for OHINO-S",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./atoms": {
      "import": "./dist/atoms/index.js",
      "types": "./dist/atoms/index.d.ts"
    },
    "./molecules": {
      "import": "./dist/molecules/index.js",
      "types": "./dist/molecules/index.d.ts"
    },
    "./organisms": {
      "import": "./dist/organisms/index.js",
      "types": "./dist/organisms/index.d.ts"
    },
    "./themes": {
      "import": "./dist/themes/index.js",
      "types": "./dist/themes/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@ohino/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
